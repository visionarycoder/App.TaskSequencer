<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Clinet.Desktop.WinUI.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="20">
            <!-- Header -->
            <StackPanel Spacing="5">
                <TextBlock Text="Execution Plan Dashboard" FontSize="32" FontWeight="Bold" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="Gray" />
            </StackPanel>

            <!-- Statistics Grid -->
            <Grid ColumnSpacing="10" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Total Tasks -->
                <Border BorderBrush="#007AFF" BorderThickness="2" CornerRadius="8" Padding="15" Grid.Row="0" Grid.Column="0">
                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Text="Total Tasks" FontSize="12" Foreground="Gray" TextAlignment="Center" />
                        <TextBlock Text="{Binding TotalTasks}" FontSize="28" FontWeight="Bold" Foreground="#007AFF" TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Valid Tasks -->
                <Border BorderBrush="#34C759" BorderThickness="2" CornerRadius="8" Padding="15" Grid.Row="0" Grid.Column="1">
                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Text="Valid Tasks" FontSize="12" Foreground="Gray" TextAlignment="Center" />
                        <TextBlock Text="{Binding ValidTasks}" FontSize="28" FontWeight="Bold" Foreground="#34C759" TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Invalid Tasks -->
                <Border BorderBrush="#FF3B30" BorderThickness="2" CornerRadius="8" Padding="15" Grid.Row="1" Grid.Column="0">
                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Text="Invalid Tasks" FontSize="12" Foreground="Gray" TextAlignment="Center" />
                        <TextBlock Text="{Binding InvalidTasks}" FontSize="28" FontWeight="Bold" Foreground="#FF3B30" TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Valid Percentage -->
                <Border BorderBrush="#17C957" BorderThickness="2" CornerRadius="8" Padding="15" Grid.Row="1" Grid.Column="1">
                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Text="Valid %" FontSize="12" Foreground="Gray" TextAlignment="Center" />
                        <TextBlock Text="{Binding ValidPercentage, StringFormat='{0:F1}%'}" FontSize="28" FontWeight="Bold" Foreground="#17C957" TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Critical Path Section -->
            <Border BorderBrush="#FF9500" BorderThickness="2" CornerRadius="8" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="Critical Path Analysis" FontSize="16" FontWeight="Bold" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Completion Time" FontSize="12" Foreground="Gray" />
                            <TextBlock Text="{Binding CriticalPathEnd}" FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="Critical Tasks" FontSize="12" Foreground="Gray" />
                            <TextBlock Text="{Binding CriticalTaskCount}" FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="Max Parallel Level" FontSize="12" Foreground="Gray" />
                            <TextBlock Text="{Binding MaxParallelLevel}" FontSize="14" FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Execution Groups" FontSize="12" Foreground="Gray" />
                            <TextBlock Text="{Binding ExecutionGroups}" FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Errors Section -->
            <Border x:Name="ErrorsBorder" BorderBrush="#FF3B30" BorderThickness="2" CornerRadius="8" Padding="15" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="Errors" FontSize="14" FontWeight="Bold" Foreground="#FF3B30" />
                    <ItemsControl ItemsSource="{Binding Errors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#FF3B30" TextWrapping="Wrap" Margin="0,5" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Warnings Section -->
            <Border x:Name="WarningsBorder" BorderBrush="#FF9500" BorderThickness="2" CornerRadius="8" Padding="15" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="Warnings" FontSize="14" FontWeight="Bold" Foreground="#FF9500" />
                    <ItemsControl ItemsSource="{Binding Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#FF9500" TextWrapping="Wrap" Margin="0,5" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Refresh Button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Background="#007AFF" Foreground="White" Padding="20,10" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
