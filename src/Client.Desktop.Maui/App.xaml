<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:App.TaskSequencer.Client.Desktop.Maui"
             xmlns:converters="clr-namespace:App.TaskSequencer.Client.Desktop.Maui.Converters"
             x:Class="App.TaskSequencer.Client.Desktop.Maui.App">
    <Application.Resources>
        <!-- Simplified resource dictionary - avoiding external resource loading that triggers COM errors -->
        <ResourceDictionary>
            <!-- Value Converters - defined inline to avoid file loading issues -->
            <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:InvertedIntToBoolConverter x:Key="InvertedIntToBoolConverter" />
            <converters:NotNullToBoolConverter x:Key="NotNullToBoolConverter" />
            <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:CriticalToColorConverter x:Key="CriticalToColorConverter" />
            <converters:SeverityToColorConverter x:Key="SeverityToColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
