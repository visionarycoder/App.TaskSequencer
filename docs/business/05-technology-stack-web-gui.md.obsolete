## Data Binding: ViewModel Pattern (MVVM)

**DashboardViewModel.cs**:
```csharp
public class DashboardViewModel : ObservableObject
{
    [ObservableProperty]
    private ExecutionPlanDto executionPlan;
    
    [ObservableProperty]
    private int totalTasks;
    
    [ObservableProperty]
    private int validTasks;
    
    [ObservableProperty]
    private int invalidTasks;
    
    [ObservableProperty]
    private ObservableCollection<ExecutionViolationDto> violations;
    
    [ObservableProperty]
    private ObservableCollection<SequenceGroupSummaryDto> groups;
    
    [ObservableProperty]
    private ConvergenceProgressDto convergenceProgress;
    
    [RelayCommand]
    private async Task LoadCsvFiles()
    {
        // File picker → load CSV paths
        var picker = new FileOpenPicker
        {
            SuggestedStartLocation = PickerLocationId.DocumentsLibrary,
            FileTypeFilter = { ".csv" }
        };
        picker.FileTypeFilter.Add(".csv");
        
        var files = await picker.PickMultipleFilesAsync();
        if (files.Count < 2) return;
        
        // Initialize Orleans & calculate plan
        await InitializeOrleansAndCalculateAsync(files);
    }
    
    private async Task InitializeOrleansAndCalculateAsync(IList<StorageFile> csvFiles)
    {
        // Load CSVs
        var taskDefs = await CsvParser.ParseTaskDefinitionsAsync(csvFiles[0]);
        var intakeEvents = await CsvParser.ParseIntakeEventsAsync(csvFiles[1]);
        
        // Initialize Orleans orchestrator
        var orchestrator = GrainFactory.GetGrain<IExecutionPlanOrchestratorGrain>("ExecutionPlan_Today");
        var plan = await orchestrator.BuildExecutionPlanAsync("today", executionInstances);
        
        // Update UI
        ExecutionPlan = new ExecutionPlanDto { /* ... */ };
        UpdateStatistics();
    }
}
```

**MainWindow.xaml**:
```xaml
<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <TransitionCollection>
        <EntranceThemeTransition />
    </TransitionCollection>
    
    <Grid RowDefinitions="Auto,*">
        <CommandBar Grid.Row="0">
            <AppBarButton Icon="OpenFile" Label="Load CSV" 
                         Command="{x:Bind ViewModel.LoadCsvFilesCommand}" />
            <AppBarButton Icon="Refresh" Label="Refresh" />
            <AppBarButton Icon="Save" Label="Export" />
        </CommandBar>
        
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="20" Spacing="20">
                
                <!-- Dashboard Stats -->
                <InfoBar Title="Execution Overview" IsOpen="True">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <StackPanel>
                            <TextBlock Text="Total Tasks" Class="SectionTitle" />
                            <TextBlock Text="{x:Bind ViewModel.TotalTasks}" FontSize="24" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Valid" Class="SectionTitle" />
                            <TextBlock Text="{x:Bind ViewModel.ValidTasks}" FontSize="24" Foreground="Green" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Invalid" Class="SectionTitle" />
                            <TextBlock Text="{x:Bind ViewModel.InvalidTasks}" FontSize="24" Foreground="Red" />
                        </StackPanel>
                    </Grid>
                </InfoBar>
                
                <!-- Convergence Progress -->
                <ProgressRing IsActive="True" IsIndeterminate="True" />
                <ItemsView ItemsSource="{x:Bind ViewModel.ConvergenceProgress.Rounds}">
                    <ItemsView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="10">
                                <TextBlock Text="{Binding RoundNumber, StringFormat='Round {0}'}" FontWeight="Bold" />
                                <TextBlock Text="{Binding TasksChanged, StringFormat='{0} tasks changed position'}" />
                                <ProgressBar Value="{Binding PercentComplete}" Height="4" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsView.ItemTemplate>
                </ItemsView>
                
                <!-- Violations Table -->
                <DataGrid ItemsSource="{x:Bind ViewModel.Violations}" 
                          AutoGenerateColumns="False"
                          ColumnHeaderHeight="40"
                          Height="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Task" Binding="{Binding InterfaceNumber}" Width="60" />
                        <DataGridTextColumn Header="Group" Binding="{Binding GroupId}" Width="100" />
                        <DataGridTextColumn Header="Deadline" Binding="{Binding Deadline}" Width="100" />
                        <DataGridTextColumn Header="Miss Amount" Binding="{Binding MissAmount}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
                
            </StackPanel>
        </ScrollView>
    </Grid>
</Window>
```

