<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Clinet.Desktop.WinUI.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="15">
            <!-- Header -->
            <StackPanel Spacing="5">
                <TextBlock Text="Execution Plan Settings" FontSize="32" FontWeight="Bold" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="Gray" />
            </StackPanel>

            <!-- File Selection Section -->
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel Spacing="15">
                    <TextBlock Text="CSV Files" FontSize="16" FontWeight="Bold" />

                    <!-- Task Definitions Path -->
                    <StackPanel Spacing="5">
                        <TextBlock Text="Task Definitions CSV" FontSize="12" FontWeight="Bold" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBlock Text="{Binding TaskDefinitionsPath}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
                            <Button Content="Browse..." Command="{Binding SelectTaskDefinitionsCommand}" Grid.Column="1" Padding="15,10" />
                        </Grid>
                    </StackPanel>

                    <!-- Intake Events Path -->
                    <StackPanel Spacing="5">
                        <TextBlock Text="Intake Events CSV" FontSize="12" FontWeight="Bold" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBlock Text="{Binding IntakeEventsPath}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
                            <Button Content="Browse..." Command="{Binding SelectIntakeEventsCommand}" Grid.Column="1" Padding="15,10" />
                        </Grid>
                    </StackPanel>

                    <!-- Duration Manifest Path -->
                    <StackPanel Spacing="5">
                        <TextBlock Text="Duration Manifest CSV (Optional)" FontSize="12" FontWeight="Bold" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBlock Text="{Binding DurationManifestPath}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
                            <Button Content="Browse..." Command="{Binding SelectDurationManifestCommand}" Grid.Column="1" Padding="15,10" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Date Range Section -->
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel Spacing="15">
                    <TextBlock Text="Increment Range" FontSize="16" FontWeight="Bold" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Start Date" FontSize="12" FontWeight="Bold" />
                            <CalendarDatePicker Date="{Binding IncrementStart, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="5" Grid.Column="1">
                            <TextBlock Text="End Date" FontSize="12" FontWeight="Bold" />
                            <CalendarDatePicker Date="{Binding IncrementEnd, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Errors Section -->
            <Border x:Name="ErrorsBorder" BorderBrush="#FF3B30" BorderThickness="2" CornerRadius="8" Padding="15" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="Errors" FontSize="14" FontWeight="Bold" Foreground="#FF3B30" />
                    <ItemsControl ItemsSource="{Binding Errors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#FF3B30" TextWrapping="Wrap" Margin="0,5" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Warnings Section -->
            <Border x:Name="WarningsBorder" BorderBrush="#FF9500" BorderThickness="2" CornerRadius="8" Padding="15" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="Warnings" FontSize="14" FontWeight="Bold" Foreground="#FF9500" />
                    <ItemsControl ItemsSource="{Binding Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#FF9500" TextWrapping="Wrap" Margin="0,5" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Execute Button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <Button Content="Execute Plan" Command="{Binding ExecutePlanCommand}" Background="#007AFF" Foreground="White" Padding="30,12" FontSize="14" FontWeight="Bold" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
