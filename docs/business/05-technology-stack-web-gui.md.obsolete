## Data Flow: API → Frontend

### Reporting DTOs (sent by ASP.NET Core API)

```csharp
// Response from GET /api/reports/{reportId}
public record ExecutionPlanDto(
    string IncrementId,
    DateTime IncrementStart,
    DateTime IncrementEnd,
    ExecutionInstanceDto[] Tasks,
    string[] TaskChain,
    int TotalValidTasks,
    int TotalInvalidTasks,
    DateTime? CriticalPathCompletion,
    string[] DeadlineMisses
);

public record ExecutionInstanceDto(
    string ExecutionInstanceKey,  // Grain key
    string InterfaceNumber,
    string InterfaceName,
    DateTime ScheduledStartTime,
    DateTime CalculatedStartTime,
    DateTime PlannedCompletionTime,
    DateTime? IntakeDeadline,
    int DurationMinutes,
    bool IsEstimatedDuration,
    bool IsValid,
    string? ValidationMessage
);

// Response from GET /api/groups/{groupId}
public record SequenceGroupReportDto(
    string GroupId,
    string GroupName,
    ExecutionPlanDto GroupPlan,
    SequenceGroupMetricsDto Metrics
);

public record SequenceGroupMetricsDto(
    int ValidTaskCount,
    int InvalidTaskCount,
    DateTime CriticalPathCompletion,
    TimeSpan TotalDuration,
    Dictionary<int, int> TasksChangedPerRound  // Round → count
);
```

### TypeScript Interfaces (Frontend)

```typescript
// src/types/execution-plan.ts
export interface ExecutionPlan {
  incrementId: string;
  incrementStart: string;  // ISO8601
  incrementEnd: string;
  tasks: ExecutionInstance[];
  taskChain: string[];
  totalValidTasks: number;
  totalInvalidTasks: number;
  criticalPathCompletion?: string;
  deadlineMisses: string[];
}

export interface ExecutionInstance {
  executionInstanceKey: string;
  interfaceNumber: string;
  interfaceName: string;
  scheduledStartTime: string;
  calculatedStartTime: string;
  plannedCompletionTime: string;
  intakeDeadline?: string;
  durationMinutes: number;
  isEstimatedDuration: boolean;
  isValid: boolean;
  validationMessage?: string;
}

export interface SequenceGroupReport {
  groupId: string;
  groupName: string;
  groupPlan: ExecutionPlan;
  metrics: SequenceGroupMetrics;
}

export interface SequenceGroupMetrics {
  validTaskCount: number;
  invalidTaskCount: number;
  criticalPathCompletion: string;
  totalDuration: string;  // Duration format
  tasksChangedPerRound: Record<number, number>;
}
```

