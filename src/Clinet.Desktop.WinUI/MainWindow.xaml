<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Clinet.Desktop.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Task Sequencer - Execution Plan Manager"
    Width="1200"
    Height="800">

    <Grid RowDefinitions="*,Auto">
        <!-- Tab Control for Navigation -->
        <TabView x:Name="MainTabView" Grid.Row="0" Margin="10">
            <TabViewItem Header="Dashboard">
                <Frame x:Name="DashboardFrame" />
            </TabViewItem>
            
            <TabViewItem Header="Timeline">
                <Frame x:Name="TimelineFrame" />
            </TabViewItem>
            
            <TabViewItem Header="Violations">
                <Frame x:Name="ViolationsFrame" />
            </TabViewItem>
            
            <TabViewItem Header="Settings">
                <Frame x:Name="SettingsFrame" />
            </TabViewItem>
        </TabView>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" Foreground="Gray" />
        </Border>
    </Grid>
</Window>
