<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="App.TaskSequencer.Client.Desktop.Maui.Views.TimelinePage"
    Title="Execution Timeline">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20" Margin="10" RowSpacing="10">
        <!-- Header -->
        <VerticalStackLayout Spacing="5">
            <Label Text="Gantt Chart - Task Execution Timeline" FontSize="24" FontAttributes="Bold" />
            <Label Text="{Binding StatusMessage}" FontSize="12" TextColor="Gray" />
        </VerticalStackLayout>

        <!-- Control Bar -->
        <HorizontalStackLayout Grid.Row="1" Spacing="10" HorizontalOptions="Center">
            <Button 
                Text="Zoom In" 
                Command="{Binding ZoomInCommand}"
                BackgroundColor="#007AFF" 
                TextColor="White"
                Padding="10" />
            <Button 
                Text="Zoom Out" 
                Command="{Binding ZoomOutCommand}"
                BackgroundColor="#007AFF" 
                TextColor="White"
                Padding="10" />
            <Label 
                Text="{Binding TimelineStart, StringFormat='Start: {0:g}'}" 
                VerticalOptions="Center" 
                FontSize="12" />
            <Label 
                Text="{Binding TimelineEnd, StringFormat='End: {0:g}'}" 
                VerticalOptions="Center" 
                FontSize="12" />
        </HorizontalStackLayout>

        <!-- Timeline Container -->
        <ScrollView Grid.Row="2" Orientation="Both">
            <VerticalStackLayout Spacing="5" Padding="10">
                <!-- Gantt Chart Header -->
                <Grid ColumnDefinitions="200,*" Padding="0,10" BackgroundColor="#F0F0F0">
                    <Label Text="Task Name" FontSize="12" FontAttributes="Bold" />
                    <Label Text="Timeline" Grid.Column="1" FontSize="12" FontAttributes="Bold" />
                </Grid>

                <!-- Task Rows -->
                <CollectionView ItemsSource="{Binding ExecutionTasks}" SelectionMode="Single" SelectionChangedCommand="{Binding SelectTaskCommand}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="200,*" Padding="0,2" Margin="0,1">
                                <!-- Task Name -->
                                <VerticalStackLayout Padding="5" Spacing="2">
                                    <Label 
                                        Text="{Binding TaskName}" 
                                        FontSize="11" 
                                        FontAttributes="Bold" 
                                        LineBreakMode="TailTruncation" />
                                    <Label 
                                        Text="{Binding TaskId, StringFormat='ID: {0}'}" 
                                        FontSize="9" 
                                        TextColor="Gray" />
                                </VerticalStackLayout>

                                <!-- Gantt Bar -->
                                <Frame 
                                    Grid.Column="1"
                                    BorderColor="Transparent"
                                    Padding="0"
                                    Margin="0,5"
                                    CornerRadius="3"
                                    HasShadow="False">
                                    <Frame.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#E0E0E0" Offset="0" />
                                            <GradientStop Color="#F0F0F0" Offset="1" />
                                        </LinearGradientBrush>
                                    </Frame.Background>

                                    <!-- Status Indicator -->
                                    <HorizontalStackLayout Spacing="0">
                                        <!-- Bar -->
                                        <BoxView 
                                            CornerRadius="2"
                                            Margin="{Binding ., Converter={StaticResource TaskBarMarginConverter}}"
                                            WidthRequest="{Binding ., Converter={StaticResource TaskBarWidthConverter}}"
                                            Color="{Binding ., Converter={StaticResource TaskColorConverter}}" />
                                    </HorizontalStackLayout>
                                </Frame>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Details Panel -->
        <Frame Grid.Row="3" BorderColor="#D0D0D0" CornerRadius="10" Padding="15" IsVisible="{Binding SelectedTask, Converter={StaticResource NotNullToBoolConverter}}">
            <VerticalStackLayout Spacing="8">
                <Label Text="Task Details" FontSize="14" FontAttributes="Bold" />
                
                <Grid ColumnDefinitions="150,*" ColumnSpacing="10">
                    <!-- Left Column -->
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Task ID:" FontSize="11" TextColor="Gray" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedTask.TaskId}" FontSize="11" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Task Name:" FontSize="11" TextColor="Gray" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedTask.TaskName}" FontSize="11" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Status:" FontSize="11" TextColor="Gray" FontAttributes="Bold" />
                            <Label 
                                Text="{Binding SelectedTask.IsValid, StringFormat='{0:Yes/No}'}" 
                                FontSize="11"
                                TextColor="{Binding SelectedTask.IsValid, Converter={StaticResource BoolToColorConverter}}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Duration:" FontSize="11" TextColor="Gray" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedTask.DurationMinutes, StringFormat='{0:F1} min'}" FontSize="11" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Right Column -->
                    <VerticalStackLayout Spacing="10" Grid.Column="1">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Scheduled Start:" FontSize="11" TextColor="Gray" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedTask.ScheduledStartTime, StringFormat='{0:g}'}" FontSize="11" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Planned Completion:" FontSize="11" TextColor="Gray" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedTask.PlannedCompletionTime, StringFormat='{0:g}'}" FontSize="11" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Slack Time:" FontSize="11" TextColor="Gray" FontAttributes="Bold" />
                            <Label 
                                Text="{Binding SelectedTask.SlackMinutes, StringFormat='{0:F1} min'}" 
                                FontSize="11"
                                TextColor="{Binding SelectedTask.IsCritical, Converter={StaticResource CriticalToColorConverter}}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
